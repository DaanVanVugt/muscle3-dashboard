ymmsl_version: v0.1
model:
  name: test_chease_actor
  components:
    source:
      ports:
        o_i:
        - equilibrium_out
      implementation: source
    sink:
      ports:
        f_init:
        - equilibrium_in
      implementation: sink
    chease:
      ports:
        f_init:
        - equilibrium_in
        o_f:
        - equilibrium_out
      implementation: chease
  conduits:
    source.equilibrium_out: chease.equilibrium_in
    chease.equilibrium_out: sink.equilibrium_in
settings:
  source.source_uri: imas:hdf5?path=/home/ITER/sanderm/gitrepos/pds/run/input/test_data_ids/
  sink.sink_uri: imas:hdf5?path=/home/ITER/sanderm/gitrepos/pds/run/output/sink_chease
  sink.sink_mode: w
  muscle_remote_log_level: DEBUG
implementations:
  source:
    virtual_env: /home/ITER/sanderm/gitrepos/pds/run/IMAS-MUSCLE3/venv
    executable: python
    args:
    - -u -m imas_muscle3.actors.source_component
  sink:
    virtual_env: /home/ITER/sanderm/gitrepos/pds/run/IMAS-MUSCLE3/venv
    executable: python
    args:
    - -u -m imas_muscle3.actors.sink_component
  chease:
    executable: /home/ITER/sanderm/gitrepos/pds/run/chease/chease_m3/bin/chease.exe
resources:
  source:
    threads: 1
  sink:
    threads: 1
  chease:
    threads: 1
